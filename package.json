{
  "name": "wow-settings-backup",
  "version": "2.0.0",
  "description": "Cross-platform WoW settings backup, sync, and cloud storage manager",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "author": "Bradley Collins",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.40",
    "@types/react-dom": "^18.2.17",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "electron": "^27.1.3",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.2",
    "vite": "^5.0.7",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "dependencies": {
    "bonjour-service": "^1.2.1",
    "dropbox": "^10.34.0",
    "electron-store": "^8.1.0",
    "googleapis": "^129.0.0",
    "lz4-napi": "^2.7.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tar-stream": "^3.1.6",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "ws": "^8.14.2"
  },
  "build": {
    "appId": "com.wowbackup.settings",
    "productName": "WoW Settings Backup",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": ["dmg"]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": ["AppImage", "deb", "rpm"]
    }
  }
}
